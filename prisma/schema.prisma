// Bukay booking platform — Prisma schema
// Multi-tenant data model. Every tenant-owned row carries a tenantId column
// and a corresponding @@index([tenantId]) for partition-friendly queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  timezone      String         @default("Africa/Lagos")
  currency      String         @default("NGN")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  services      Service[]
  staff         Staff[]
  businessHours BusinessHour[]
  clients       Client[]
  bookings      Booking[]
  payments      Payment[]
  auditLogs     AuditLog[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  name      String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Service {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  priceKobo       Int
  currency        String    @default("NGN")
  active          Boolean   @default(true)
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Staff {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  active    Boolean   @default(true)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model BusinessHour {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  opensAt   String
  closesAt  String
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model Client {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String
  notes     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Booking {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffId   String?
  staff     Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  startsAt  DateTime
  endsAt    DateTime
  status    String    @default("pending")
  notes     String?
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([clientId])
  @@index([serviceId])
  @@index([staffId])
}

model Payment {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String    @default("NGN")
  provider    String?
  providerRef String?
  status      String    @default("pending")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([bookingId])
  @@index([providerRef])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// -----------------------------------------------------------------------------
// Tenant — the root of the multi-tenant tree
// -----------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  timezone  String   @default("Africa/Lagos")
  currency  String   @default("NGN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  services      Service[]
  staff         Staff[]
  businessHours BusinessHour[]
  clients       Client[]
  bookings      Booking[]
  payments      Payment[]
  auditLogs     AuditLog[]

  @@index([slug])
}

// -----------------------------------------------------------------------------
// User — login identities scoped to a tenant
// -----------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff     Staff?
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Service — offerings the tenant sells
// -----------------------------------------------------------------------------

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  priceKobo       Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
  staff    Staff[]   @relation("StaffServices")

  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Staff — people that fulfil bookings
// -----------------------------------------------------------------------------

model Staff {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  @unique
  name      String
  email     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  services      Service[]      @relation("StaffServices")
  bookings      Booking[]
  businessHours BusinessHour[]

  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// BusinessHour — weekly availability for a tenant (or a specific staff member)
// -----------------------------------------------------------------------------

model BusinessHour {
  id          String    @id @default(cuid())
  tenantId    String
  staffId     String?
  dayOfWeek   DayOfWeek
  openMinute  Int
  closeMinute Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff  Staff? @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, staffId, dayOfWeek])
}

// -----------------------------------------------------------------------------
// Client — end customers who book services
// -----------------------------------------------------------------------------

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId])
}

// -----------------------------------------------------------------------------
// Booking — the appointment itself
// -----------------------------------------------------------------------------

model Booking {
  id        String        @id @default(cuid())
  tenantId  String
  clientId  String
  serviceId String
  staffId   String?
  startsAt  DateTime
  endsAt    DateTime
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service  Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff    Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([tenantId, staffId, startsAt])
}

// -----------------------------------------------------------------------------
// Payment — money received against a booking
// -----------------------------------------------------------------------------

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  bookingId   String
  amountCents Int
  currency    String
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  externalRef String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, bookingId])
}

// -----------------------------------------------------------------------------
// AuditLog — append-only history of tenant-scoped actions
// -----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}
