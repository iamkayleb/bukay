// Bukay booking platform — Prisma schema
// Multi-tenant data model. Every tenant-owned row carries a tenantId column
// and a corresponding @@index([tenantId]) for partition-friendly queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  timezone      String         @default("Africa/Lagos")
  currency      String         @default("NGN")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  services      Service[]
  staff         Staff[]
  businessHours BusinessHour[]
  clients       Client[]
  bookings      Booking[]
  payments      Payment[]
  auditLogs     AuditLog[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  name      String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Service {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  currency        String    @default("NGN")
  active          Boolean   @default(true)
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Staff {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  active    Boolean   @default(true)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model BusinessHour {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  opensAt   String
  closesAt  String
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model Client {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String
  notes     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Booking {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffId   String?
  staff     Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  startsAt  DateTime
  endsAt    DateTime
  status    String    @default("pending")
  notes     String?
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([clientId])
  @@index([serviceId])
  @@index([staffId])
}

model Payment {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String    @default("NGN")
  provider    String?
  providerRef String?
  status      String    @default("pending")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([bookingId])
  @@index([providerRef])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
}

