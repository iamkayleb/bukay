# Prisma datasource URL.
# Copy this file to .env and update with real credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bukay?schema=public"

# Signing secret for HTTP-only session cookies. Must be >= 16 chars.
SESSION_SECRET="change-me-to-a-long-random-string"

# SMS provider for OTP delivery. "termii" uses TermiiProvider; anything else uses
# an in-memory provider (useful for local dev / tests).
SMS_PROVIDER="memory"
TERMII_API_KEY=""
TERMII_SENDER_ID="Bukay"
# TERMII_BASE_URL="https://api.ng.termii.com"
# TERMII_CHANNEL="generic"
